{
  "name": "@ksefuj/validator",
  "version": "0.2.0",
  "description": "KSeF FA(3) XML validator — XSD schema and semantic rules validation, works in Node and browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types-export.js",
      "types": "./dist/types-export.d.ts"
    },
    "./validate": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ksef-validate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "validate": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest --coverage --run"
  },
  "files": [
    "dist",
    "!dist/**/*.xsd",
    "!dist/**/*.ts",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/__tests__"
  ],
  "keywords": [
    "ksef",
    "faktura",
    "invoice",
    "validator",
    "xml",
    "xsd",
    "poland",
    "e-invoicing",
    "fa3"
  ],
  "author": "ksefuj contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ksefuj/ksefuj.git",
    "directory": "packages/validator"
  },
  "homepage": "https://ksefuj.to",
  "bugs": {
    "url": "https://github.com/ksefuj/ksefuj/issues"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "libxml2-wasm": "^0.7.1"
  }
}
