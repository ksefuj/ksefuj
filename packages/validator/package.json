{
  "name": "@ksefuj/validator",
  "version": "0.2.0",
  "description": "KSeF FA(3) XML validator — XSD schema validation, works in Node and browser (semantic rules TBD)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/types-export.js",
      "types": "./dist/types-export.d.ts"
    },
    "./validate": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ksef-validate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "validate": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest --coverage --run"
  },
  "files": [
    "dist",
    "!dist/**/*.xsd",
    "!dist/**/*.ts",
    "dist/**/*.d.ts"
  ],
  "keywords": [
    "ksef",
    "fa3",
    "e-faktura",
    "xml",
    "validator",
    "poland",
    "invoice"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "libxml2-wasm": "^0.7.1"
  }
}
