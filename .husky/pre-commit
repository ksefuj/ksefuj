# Run format check
pnpm format:check || (
  echo "❌ Formatting issues found. Run 'pnpm format' to fix them."
  exit 1
)

# Run lint
pnpm lint || (
  echo "❌ Linting issues found. Fix them before committing."
  exit 1
)

# Run typecheck
pnpm typecheck || (
  echo "❌ TypeScript errors found. Fix them before committing."
  exit 1
)

# Run SEO validation (currently in warning mode)
# TODO: Enable strict mode after fixing existing issues
pnpm validate:seo || (
  echo "⚠️  SEO issues found (non-blocking for now)."
  echo "💡 Run 'pnpm validate:seo' to see details."
  # exit 1 # Uncomment to enforce
)
