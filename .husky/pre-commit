# Bootstrap content directory structure and stage any new content files
pnpm setup-content
git add apps/web/content/ 2>/dev/null || true

# Run format check
pnpm format:check || (
  echo "❌ Formatting issues found. Run 'pnpm format' to fix them."
  exit 1
)

# Run lint
pnpm lint || (
  echo "❌ Linting issues found. Fix them before committing."
  exit 1
)

# Run typecheck
pnpm typecheck || (
  echo "❌ TypeScript errors found. Fix them before committing."
  exit 1
)